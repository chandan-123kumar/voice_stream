# Copy to .env and fill in. voice_agent.py loads this at startup.

# Required: OpenAI key used for the LLM (and STT when STT_BACKEND=openai).
OPENAI_API_KEY=

# Optional overrides (defaults shown).
#OPENAI_LLM_MODEL=gpt-4o-mini
#TTS_SPEAKER=ryan
#VOICE_AGENT_PORT=8001

# STT: "whisper" = local faster-whisper on the GPU (default, lowest latency),
# "openai" = hosted realtime STT (no local VRAM, needs network round-trips).
#STT_BACKEND=whisper
#WHISPER_MODEL=deepdml/faster-whisper-large-v3-turbo-ct2
#WHISPER_DEVICE=cuda
#WHISPER_COMPUTE=float16
#OPENAI_STT_MODEL=gpt-realtime-whisper
